{
  "database": {
    "rules": "FIREBASE_SECURITY_RULES.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/submitTransferOrder",
        "function": "submitTransferOrder"
      },
      {
        "source": "/api/requestQrTransfer",
        "function": "requestQrTransfer"
      },
      {
        "source": "/api/acceptQrTransfer",
        "function": "acceptQrTransfer"
      },
      {
        "source": "/api/resendTicketQrEmail",
        "function": "resendTicketQrEmail"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
