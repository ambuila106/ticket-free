{
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/prepareWompiPayment",
        "function": "prepareWompiPayment"
      },
      {
        "source": "/api/wompiWebhook",
        "function": "wompiWebhook"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
